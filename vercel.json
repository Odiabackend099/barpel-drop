{
  "framework": "nextjs",
  "github": {
    "enabled": false,
    "silent": true
  },
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/dial-pending",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/data-cleanup",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/activation-check",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/dunning-check",
      "schedule": "0 10 * * *"
    }
  ],
  "functions": {
    "app/api/onboarding/complete/**": { "maxDuration": 300 },
    "app/api/provisioning/**": { "maxDuration": 300 },
    "app/api/merchant/ai-voice/**": { "maxDuration": 60 },
    "app/api/vapi/**": { "maxDuration": 30 },
    "app/api/billing/webhook/**": { "maxDuration": 30 },
    "app/api/**": { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
