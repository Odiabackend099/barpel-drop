# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Vapi
VAPI_PRIVATE_KEY=vapi_your_key
VAPI_WEBHOOK_SECRET=your_webhook_secret

# Twilio — Barpel's platform account (server side only — never exposed to merchants)
TWILIO_ACCOUNT_SID=AC_your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_UK_ADDRESS_SID=
TWILIO_US_ADDRESS_SID=

# Shopify OAuth App
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
# Shopify app handle — found in Partner Dashboard → Apps → [App] → App setup
# e.g. NEXT_PUBLIC_SHOPIFY_APP_HANDLE=barpel-ai
# When set, the "Manage in Shopify Admin" button deep-links to the Barpel subscription page.
# When not set, falls back to /admin/settings/billing (still functional).
NEXT_PUBLIC_SHOPIFY_APP_HANDLE=

# AfterShip
AFTERSHIP_API_KEY=your_aftership_key

# App
NEXT_PUBLIC_BASE_URL=https://your-domain.com
NODE_ENV=production
