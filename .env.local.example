# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Vapi
VAPI_PRIVATE_KEY=vapi_your_key
VAPI_WEBHOOK_SECRET=your_webhook_secret

# Twilio (subaccount credentials — used by provisioning)
TWILIO_SUBACCOUNT_SID=AC_your_subaccount_sid
TWILIO_SUBACCOUNT_AUTH_TOKEN=your_subaccount_auth_token
TWILIO_UK_ADDRESS_SID=
TWILIO_US_ADDRESS_SID=

# Shopify OAuth App
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_key
STRIPE_SECRET_KEY=sk_live_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# AfterShip
AFTERSHIP_API_KEY=your_aftership_key

# App
NEXT_PUBLIC_BASE_URL=https://your-domain.com
NODE_ENV=production
